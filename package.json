{
  "name": "llmstxt-kit",
  "version": "0.1.0",
  "description": "Toolchain for the llms.txt spec: generate, lint and diff llms.txt / llms-full.txt from any Markdown docs tree. Zero runtime dependencies, fully offline.",
  "author": "JaydenCJ <aisingioro.kiyon@gmail.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "llmstxt": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"tests/*.test.mjs\"",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [
    "llms.txt",
    "llms-full.txt",
    "ai-crawlers",
    "documentation",
    "markdown",
    "linter",
    "generator",
    "seo"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaydenCJ/llmstxt-kit.git"
  },
  "homepage": "https://github.com/JaydenCJ/llmstxt-kit#readme",
  "bugs": {
    "url": "https://github.com/JaydenCJ/llmstxt-kit/issues"
  }
}
